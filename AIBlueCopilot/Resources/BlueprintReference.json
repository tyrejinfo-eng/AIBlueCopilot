  "blueprint_creation_guide": {
    "step_1": "Identify the purpose of the blueprint (character, prop, effect, etc.)",
    "step_2": "Select appropriate parent class (Character, Pawn, or Actor)",
    "step_3": "Reference this guide for similar blueprints",
    "step_4": "Create with specific name (BP_NameHere format)",
    "step_5": "Add necessary components and properties",
    "step_6": "Save to /Game/EasyToFind/ folder",
    "tip": "Use descriptive names starting with BP_ prefix for better organization"
  },

  "quick_blueprint_lookup": {
    "I need a player character": "BP_PlayerCharacter (Character parent)",
