#include "AIBlueCopilotEditor.h"
#include "Framework/Docking/TabManager.h"
#include "Widgets/Docking/SDockTab.h"
#include "Widgets/Text/STextBlock.h"
#include "Widgets/Layout/SBox.h"
#include "Widgets/Layout/SVerticalBox.h"

DEFINE_LOG_CATEGORY_STATIC(LogAIBlueCopilotEditor, Log, All);

static const FName AIBlueCopilotTabName(TEXT("AIBlueCopilot"));

TSharedRef<SDockTab> SpawnAIBlueCopilotTab(const FSpawnTabArgs& Args)
{
    return SNew(SDockTab)
        .TabRole(ETabRole::NomadTab)
        [
            SNew(SBox).Padding(8)
            [
                SNew(SVerticalBox)
                + SVerticalBox::Slot().AutoHeight().Padding(4)
                [
                    SNew(STextBlock).Text(FText::FromString("AIBlue Copilot - minimal UI (editor rebuild placeholder)"))
                ]
            ]
        ];
}

TSharedRef<SDockTab> FAIBlueCopilotEditorModule::OnSpawnPluginTab(const FSpawnTabArgs& SpawnTabArgs)
{
    return SpawnAIBlueCopilotTab(SpawnTabArgs);
}

void FAIBlueCopilotEditorModule::StartupModule()
{
    UE_LOG(LogAIBlueCopilotEditor, Warning, TEXT("[AIBLUE Copilot] Editor module starting up"));

    FGlobalTabmanager::Get()->RegisterNomadTabSpawner(AIBlueCopilotTabName, FOnSpawnTab::CreateRaw(this, &FAIBlueCopilotEditorModule::OnSpawnPluginTab))
        .SetDisplayName(FText::FromString("AIBlue Copilot"))
        .SetMenuType(ETabSpawnerMenuType::Hidden);
}

void FAIBlueCopilotEditorModule::ShutdownModule()
{
    if (FGlobalTabmanager::Get().IsValid())
    {
        FGlobalTabmanager::Get()->UnregisterNomadTabSpawner(AIBlueCopilotTabName);
    }
}

IMPLEMENT_MODULE(FAIBlueCopilotEditorModule, AIBlueCopilotEditor)

#include "Framework/Docking/TabManager.h"
#include "Widgets/Docking/SDockTab.h"
#include "Widgets/Text/STextBlock.h"
#include "Widgets/Layout/SBox.h"
#include "Widgets/Layout/SVerticalBox.h"

DEFINE_LOG_CATEGORY_STATIC(LogAIBlueCopilotEditor, Log, All);

static const FName AIBlueCopilotTabName(TEXT("AIBlueCopilot"));

TSharedRef<SDockTab> SpawnAIBlueCopilotTab(const FSpawnTabArgs& Args)
{
    return SNew(SDockTab)
        .TabRole(ETabRole::NomadTab)
        [
            SNew(SBox).Padding(8)
            [
                SNew(SVerticalBox)
                + SVerticalBox::Slot().AutoHeight().Padding(4)
                [
                    SNew(STextBlock).Text(FText::FromString("AIBlue Copilot - minimal UI (editor rebuild placeholder)"))
                ]
            ]
        ];
}

TSharedRef<SDockTab> FAIBlueCopilotEditorModule::OnSpawnPluginTab(const FSpawnTabArgs& SpawnTabArgs)
{
    return SpawnAIBlueCopilotTab(SpawnTabArgs);
}

void FAIBlueCopilotEditorModule::StartupModule()
{
    UE_LOG(LogAIBlueCopilotEditor, Warning, TEXT("[AIBLUE Copilot] Editor module starting up"));

    FGlobalTabmanager::Get()->RegisterNomadTabSpawner(AIBlueCopilotTabName, FOnSpawnTab::CreateRaw(this, &FAIBlueCopilotEditorModule::OnSpawnPluginTab))
        .SetDisplayName(FText::FromString("AIBlue Copilot"))
        .SetMenuType(ETabSpawnerMenuType::Hidden);                                    );
                                    FSlateApplication::Get().AddWindow(SigninWin);
                                    return FReply::Handled();
                                })
                            ]

                            + SVerticalBox::Slot().AutoHeight().Padding(2)
                            [
                                SNew(SButton)
                                .Text(FText::FromString("Visual Studio Copilot (Sign in)"))
                                .OnClicked_Lambda([]() -> FReply {
                                    // Prefer using device flow for VS - but fallback to manual token if needed
                                    TSharedRef<SWindow> SigninWin = SNew(SWindow).Title(FText::FromString("Sign into standard LLM: Visual Studio Copilot")).ClientSize(FVector2D(520,160));
                                    TSharedPtr<SEditableTextBox> TokenBox;
                                    SigninWin->SetContent(
                                        SNew(SVerticalBox)
                                        + SVerticalBox::Slot().AutoHeight().Padding(6)[ SNew(STextBlock).Text(FText::FromString("You may use manual token entry or start Device Code flow in Settings")) ]
                                        + SVerticalBox::Slot().AutoHeight().Padding(6)[ SAssignNew(TokenBox, SEditableTextBox).HintText(FText::FromString("token...")) ]
                                        + SVerticalBox::Slot().AutoHeight().HAlign(HAlign_Right).Padding(6)[ SNew(SButton).Text(FText::FromString("Save Token")).OnClicked_Lambda([TokenBox, SigninWin]() -> FReply { FString Token = TokenBox->GetText().ToString(); if (!Token.IsEmpty()) { FString Protected; if (TokenStorage::ProtectString(Token, Protected)) { GConfig->SetString(TEXT("AIBlueCopilot"), TEXT("Visual_Studio_Copilot_Token_Protected"), *Protected, GEditorPerProjectIni); } else { GConfig->SetString(TEXT("AIBlueCopilot"), TEXT("Visual_Studio_Copilot_Token"), *Token, GEditorPerProjectIni); } GConfig->SetString(TEXT("AIBlueCopilot"), TEXT("SelectedService"), TEXT("Visual Studio Copilot"), GEditorPerProjectIni); GConfig->Flush(false, GEditorPerProjectIni);
                                                    if (GEditor)
                                                    {
                                                        UWorld* EditorWorld = GEditor->GetEditorWorldContext().World();
                                                        if (EditorWorld)
                                                        {
                                                            FString Current = UAIBlueCopilotLibrary::GetLMStudioURL(EditorWorld);
                                                            UAIBlueCopilotLibrary::InitializeCopilot(EditorWorld, Current);
                                                        }
                                                    }
                                                } FSlateApplication::Get().RequestDestroyWindow(SigninWin); return FReply::Handled(); }) ]
                                    );
                                    FSlateApplication::Get().AddWindow(SigninWin);
                                    return FReply::Handled();
                                })
                            ]
                        ]
                    ]
                    + SHorizontalBox::Slot().AutoWidth().Padding(12).VAlign(VAlign_Center)
                    [
                        SNew(SCheckBox)
                        .IsChecked(ECheckBoxState::Unchecked)
                        .OnCheckStateChanged_Lambda([](ECheckBoxState NewState) {
                            // set immediately in config
                            if (GEditor)
                            {
                                UWorld* EditorWorld = GEditor->GetEditorWorldContext().World();
                                if (EditorWorld)
                                {
                                    bool bAllow = (NewState == ECheckBoxState::Checked);
                                    UAIBlueCopilotLibrary::SetAllowAssetChanges(EditorWorld, bAllow);
                                }
                            }
                        })
                    ]
                    + SHorizontalBox::Slot().AutoWidth().Padding(2).VAlign(VAlign_Center)
                    [
                        SNew(STextBlock).Text(FText::FromString("Allow Copilot to modify project assets"))
                    ]
                ]

                + SVerticalBox::Slot().AutoHeight().Padding(4)
                [
                    SNew(SHorizontalBox)
                    + SHorizontalBox::Slot().AutoWidth().Padding(2)
                    [
                        SNew(SButton)
                        .Text(FText::FromString("Apply"))
                        .OnClicked_Lambda([]() -> FReply {
                            if (GEditor && LMUrlTextBox.IsValid() && UseLocalHostCheckBox.IsValid())
                            {
                                UWorld* EditorWorld = GEditor->GetEditorWorldContext().World();
                                if (EditorWorld)
                                {
                                    // Persist that we've attempted a connection (affects Connection display)
                                    GConfig->SetBool(TEXT("AIBlueCopilot"), TEXT("HasAttemptedConnect"), true, GEditorPerProjectIni);

                                    // If custom URL present, save it
                                    if (DevUrlTextBox.IsValid())
                                    {
                                        const FString Custom = DevUrlTextBox->GetText().ToString();
                                        if (!Custom.IsEmpty())
                                        {
                                            GConfig->SetString(TEXT("AIBlueCopilot"), TEXT("CustomServiceUrl"), *Custom, GEditorPerProjectIni);
                                            GConfig->Flush(false, GEditorPerProjectIni);
                                        }
                                    }

                                    UAIBlueCopilotLibrary::SetLMStudioURL(EditorWorld, UAIBlueCopilotLibrary::GetLMStudioURL(EditorWorld));
                                    UE_LOG(LogAIBlueCopilotEditor, Log, TEXT("[AIBLUE Copilot] Apply pressed. Service=%s"), *SelectedService);

                                    // immediate feedback
                                    if (StatusTextBlock.IsValid())
                                    {
                                        StatusTextBlock->SetText(FText::FromString("Settings applied"));
                                    }
                                }
                            }
                            return FReply::Handled();
                        })
                    ]

                    + SHorizontalBox::Slot().AutoWidth().Padding(2)
                    [
                        SNew(SButton)
                        .Text(FText::FromString("Initialize Copilot"))
                        .OnClicked_Lambda([]() -> FReply {
                            if (GEditor)
                            {
                                UWorld* EditorWorld = GEditor->GetEditorWorldContext().World();
                                if (EditorWorld && LMUrlTextBox.IsValid() && UseLocalHostCheckBox.IsValid())
                                {
                                    bool bUseLocal = (static_cast<uint8>(UseLocalHostCheckBox->IsChecked()) == static_cast<uint8>(ECheckBoxState::Checked));
                                    FString FinalURL = LMUrlTextBox->GetText().ToString();
				// If user selects ChatGPT service, use OpenAI base URL instead of LM Studio URL
				FString SelService;
				GConfig->GetString(TEXT("AIBlueCopilot"), TEXT("SelectedService"), SelService, GEditorPerProjectIni);
				if (SelService == TEXT("ChatGPT"))
				{
					FinalURL = TEXT("https://api.openai.com");
				}
				else if (bUseLocal)
				{
					FinalURL = TEXT("http://localhost:1234");
				}

                                    UAIBlueCopilotLibrary::SetLMStudioURL(EditorWorld, FinalURL);
                                    UAIBlueCopilotLibrary::SetUseLocalhost(EditorWorld, bUseLocal);
                                    UAIBlueCopilotLibrary::GetCopilotInstance(EditorWorld);
                                    UAIBlueCopilotLibrary::InitializeCopilot(EditorWorld, FinalURL);

                                    UE_LOG(LogAIBlueCopilotEditor, Warning, TEXT("[AIBLUE Copilot] Initialize button pressed from Editor UI (URL=%s, UseLocal=%d)"), *FinalURL, (int)bUseLocal);

                                    // Visible editor notification so initialization is obvious to the user
                                    if (StatusTextBlock.IsValid())
                                    {
                                        StatusTextBlock->SetText(FText::FromString("Initializing..."));
                                    }

                                    if (ErrorTextBox.IsValid())
                                    {
                                        ErrorTextBox->SetText(FText::GetEmpty());
                                    }

                                    if (LoadingIndicatorText.IsValid())
                                    {
                                        LoadingIndicatorText->SetText(FText::FromString("Loading"));
                                        LoadingIndicatorText->SetVisibility(EVisibility::Visible);
                                    }

                                    FNotificationInfo InitInfo(FText::FromString(FString::Printf(TEXT("Initializing Copilot at %s"), *FinalURL)));
                                    InitInfo.FadeOutDuration = 1.0f;
                                    InitInfo.ExpireDuration = 5.0f;
                                    FSlateNotificationManager::Get().AddNotification(InitInfo);

                                    // Start a ticker that polls for connection status and response updates
                                    double StartTime = FPlatformTime::Seconds();
                                    double Timeout = UAIBlueCopilotLibrary::GetPollTimeoutSeconds(EditorWorld); // seconds (allow more time for large models or slow responses)
                                    TWeakObjectPtr<UWorld> WeakEditorWorldForInit(EditorWorld);
                                    FTSTicker::GetCoreTicker().AddTicker(FTickerDelegate::CreateLambda([WeakEditorWorldForInit, StartTime, Timeout](float DeltaTime) -> bool {
                                        UWorld* EditorWorldPtr = WeakEditorWorldForInit.Get();
                                        if (!EditorWorldPtr)
                                        {
                                            return false;
                                        }

                                        bool bReady = UAIBlueCopilotLibrary::IsCopilotReady(EditorWorldPtr);
                                        if (StatusTextBlock.IsValid())
                                        {
                                            StatusTextBlock->SetText(FText::FromString(bReady ? TEXT("Connected") : TEXT("Initializing...")));
                                        }

                                        if (bReady)
                                        {
                                            if (LoadingIndicatorText.IsValid())
                                            {
                                                LoadingIndicatorText->SetVisibility(EVisibility::Collapsed);
                                            }

                                            FNotificationInfo ConnectedInfo(FText::FromString(TEXT("Copilot connected")));
                                            ConnectedInfo.FadeOutDuration = 1.0f;
                                            ConnectedInfo.ExpireDuration = 3.0f;
                                            FSlateNotificationManager::Get().AddNotification(ConnectedInfo);
                                            return false; // stop ticker
                                        }

                                        if (FPlatformTime::Seconds() - StartTime > Timeout)
                                        {
                                            if (StatusTextBlock.IsValid())
                                            {
                                                StatusTextBlock->SetText(FText::FromString(TEXT("Failed to connect")));
                                            }

                                            if (LoadingIndicatorText.IsValid())
                                            {
                                                LoadingIndicatorText->SetVisibility(EVisibility::Collapsed);
                                            }

                                            // show error details if available
                                            if (ErrorTextBox.IsValid())
                                            {
                                                FString Err = UAIBlueCopilotLibrary::GetLastError(EditorWorldPtr);
                                                ErrorTextBox->SetText(FText::FromString(Err.IsEmpty() ? TEXT("Failed to connect - no details") : Err));
                                            }

                                            FNotificationInfo FailedInfo(FText::FromString(TEXT("Failed to connect to Copilot")));
                                            FailedInfo.FadeOutDuration = 1.0f;
                                            FailedInfo.ExpireDuration = 5.0f;
                                            FSlateNotificationManager::Get().AddNotification(FailedInfo);
                                            return false; // stop ticker
                                        }

                                        return true; // keep polling
                                    }), UAIBlueCopilotLibrary::GetPollIntervalSeconds(EditorWorld));
                                }
                            }
                            return FReply::Handled();
                        })
                    ]

                    + SHorizontalBox::Slot().AutoWidth().Padding(2)
                    [
                        SNew(SButton)
                        .Text(FText::FromString("Health Check"))
                        .OnClicked_Lambda([]() -> FReply {
                            if (!GEditor) return FReply::Handled();
                            UWorld* EditorWorld = GEditor->GetEditorWorldContext().World();
                            if (!EditorWorld) return FReply::Handled();

                            // Choose endpoint and optionally token based on selected service
                            FString SelectedServiceLocal;
                            GConfig->GetString(TEXT("AIBlueCopilot"), TEXT("SelectedService"), SelectedServiceLocal, GEditorPerProjectIni);

                            FString CheckUrl;
                            FString AuthToken;

                            if (SelectedServiceLocal == TEXT("ChatGPT") || SelectedServiceLocal == TEXT("GitHub Copilot"))
                            {
                                if (SelectedServiceLocal == TEXT("ChatGPT"))
                                {
                                    CheckUrl = TEXT("https://api.openai.com/v1/models");
                                    GetTokenForService(TEXT("ChatGPT_Token_Protected"), TEXT("ChatGPT_Token"), AuthToken);
                                }
                                else // GitHub Copilot
                                {
                                    CheckUrl = TEXT("https://api.github.com/");
                                    GetTokenForService(TEXT("GitHubCopilot_Token_Protected"), TEXT("GitHubCopilot_Token"), AuthToken);
                                }
                            }
                            else
                            {
                                CheckUrl = UAIBlueCopilotLibrary::GetLMStudioURL(EditorWorld);
                                if (!CheckUrl.EndsWith(TEXT("/"))) CheckUrl += TEXT("");
                                CheckUrl += TEXT("/v1/models");
                            }

                            FHttpModule* Http = &FHttpModule::Get();
                            if (!Http) return FReply::Handled();

                            TSharedRef<IHttpRequest, ESPMode::ThreadSafe> Request = Http->CreateRequest();
                            Request->SetURL(CheckUrl);
                            Request->SetVerb(TEXT("GET"));
                            Request->SetHeader(TEXT("Content-Type"), TEXT("application/json"));
                            if (!AuthToken.IsEmpty()) Request->SetHeader(TEXT("Authorization"), FString::Printf(TEXT("Bearer %s"), *AuthToken));

                            Request->OnProcessRequestComplete().BindLambda([CheckUrl](FHttpRequestPtr Req, FHttpResponsePtr Response, bool bWasSuccessful) {
                                AsyncTask(ENamedThreads::GameThread, [CheckUrl, Response, bWasSuccessful]() {
                                    if (!bWasSuccessful || !Response.IsValid())
                                    {
                                        UE_LOG(LogAIBlueCopilotEditor, Error, TEXT("[AIBLUE Copilot] Health check failed to reach %s"), *CheckUrl);
                                        if (ErrorTextBox.IsValid()) ErrorTextBox->SetText(FText::FromString(TEXT("Health check failed to reach endpoint")));
                                        return;
                                    }
                                    int32 Status = Response->GetResponseCode();
                                    FString Body = Response->GetContentAsString();
                                    UE_LOG(LogAIBlueCopilotEditor, Log, TEXT("[AIBLUE Copilot] Health check status: %d, body: %s"), Status, *Body);

                                    if (Status == 401 || Status == 403)
                                    {
                                        if (ErrorTextBox.IsValid()) ErrorTextBox->SetText(FText::FromString(TEXT("Unauthorized token - please re-enter token in Settings")));
                                        if (StatusTextBlock.IsValid()) StatusTextBlock->SetText(FText::FromString(TEXT("Unauthorized")));
                                        if (ResponseTextBlock.IsValid()) ResponseTextBlock->SetText(FText::FromString(Body));
                                        return;
                                    }

                                    if (ErrorTextBox.IsValid()) ErrorTextBox->SetText(FText::FromString(FString::Printf(TEXT("Status: %d"), Status)));
                                    if (ResponseTextBlock.IsValid()) ResponseTextBlock->SetText(FText::FromString(Body));
                                });
                            });

                            Request->ProcessRequest();
                            return FReply::Handled();
                        })
                        ]

                    + SHorizontalBox::Slot().AutoWidth().Padding(2)
                    [
                        SNew(SButton)
                        .Text(FText::FromString("Test Token"))
                        .OnClicked_Lambda([]() -> FReply {
                            if (!GEditor) return FReply::Handled();
                            UWorld* EditorWorld = GEditor->GetEditorWorldContext().World();
                            if (!EditorWorld) return FReply::Handled();

                            FString SelectedServiceLocal;
                            GConfig->GetString(TEXT("AIBlueCopilot"), TEXT("SelectedService"), SelectedServiceLocal, GEditorPerProjectIni);

                            if (SelectedServiceLocal == TEXT("ChatGPT") || SelectedServiceLocal == TEXT("GitHub Copilot"))
                            {
                                FString Token;
                                if (SelectedServiceLocal == TEXT("ChatGPT"))
                                {
                                    if (!GetTokenForService(TEXT("ChatGPT_Token_Protected"), TEXT("ChatGPT_Token"), Token))
                                    {
                                        if (ErrorTextBox.IsValid()) ErrorTextBox->SetText(FText::FromString(TEXT("No ChatGPT token set")));
                                        return FReply::Handled();
                                    }

                                    // Build a small chat completion request
                                    TSharedPtr<FJsonObject> Root = MakeShareable(new FJsonObject());
                                    Root->SetStringField(TEXT("model"), TEXT("gpt-3.5-turbo"));
                                    TArray<TSharedPtr<FJsonValue>> Messages;
                                    TSharedPtr<FJsonObject> Msg = MakeShareable(new FJsonObject());
                                    Msg->SetStringField(TEXT("role"), TEXT("user"));
                                    Msg->SetStringField(TEXT("content"), TEXT("Say 'Test successful' if token works"));
                                    Messages.Add(MakeShareable(new FJsonValueObject(Msg)));
                                    Root->SetArrayField(TEXT("messages"), Messages);
                                    FString Body; TSharedRef<TJsonWriter<>> Writer = TJsonWriterFactory<>::Create(&Body);
                                    FJsonSerializer::Serialize(Root.ToSharedRef(), Writer);

                                    TSharedRef<IHttpRequest, ESPMode::ThreadSafe> Request = FHttpModule::Get().CreateRequest();
                                    Request->SetURL(TEXT("https://api.openai.com/v1/chat/completions"));
                                    Request->SetVerb(TEXT("POST"));
                                    Request->SetHeader(TEXT("Content-Type"), TEXT("application/json"));
                                    Request->SetHeader(TEXT("Authorization"), FString::Printf(TEXT("Bearer %s"), *Token));
                                    Request->SetContentAsString(Body);

                                    Request->OnProcessRequestComplete().BindLambda([](FHttpRequestPtr Req, FHttpResponsePtr Response, bool bWasSuccessful) {
                                        AsyncTask(ENamedThreads::GameThread, [Response, bWasSuccessful]() {
                                            if (!bWasSuccessful || !Response.IsValid())
                                            {
                                                if (ErrorTextBox.IsValid()) ErrorTextBox->SetText(FText::FromString(TEXT("Token test failed - no response")));
                                                return;
                                            }
                                            int32 Status = Response->GetResponseCode();
                                            FString RespBody = Response->GetContentAsString();
                                            if (Status == 401 || Status == 403)
                                            {
                                                if (ErrorTextBox.IsValid()) ErrorTextBox->SetText(FText::FromString(TEXT("Unauthorized token - please re-enter token in Settings")));
                                                if (ResponseTextBlock.IsValid()) ResponseTextBlock->SetText(FText::FromString(RespBody));
                                                return;
                                            }
                                            if (ResponseTextBlock.IsValid()) ResponseTextBlock->SetText(FText::FromString(RespBody));
                                        });
                                    });

                                    Request->ProcessRequest();
                                    return FReply::Handled();
                                }
                                else // GitHub Copilot
                                {
                                    if (!GetTokenForService(TEXT("GitHubCopilot_Token_Protected"), TEXT("GitHubCopilot_Token"), Token))
                                    {
                                        if (ErrorTextBox.IsValid()) ErrorTextBox->SetText(FText::FromString(TEXT("No GitHub Copilot token set")));
                                        return FReply::Handled();
                                    }

                                    TSharedRef<IHttpRequest, ESPMode::ThreadSafe> Request = FHttpModule::Get().CreateRequest();
                                    Request->SetURL(TEXT("https://api.github.com/"));
                                    Request->SetVerb(TEXT("GET"));
                                    Request->SetHeader(TEXT("Content-Type"), TEXT("application/json"));
                                    Request->SetHeader(TEXT("Authorization"), FString::Printf(TEXT("Bearer %s"), *Token));

                                    Request->OnProcessRequestComplete().BindLambda([](FHttpRequestPtr Req, FHttpResponsePtr Response, bool bWasSuccessful) {
                                        AsyncTask(ENamedThreads::GameThread, [Response, bWasSuccessful]() {
                                            if (!bWasSuccessful || !Response.IsValid())
                                            {
                                                if (ErrorTextBox.IsValid()) ErrorTextBox->SetText(FText::FromString(TEXT("Token test failed - no response")));
                                                return;
                                            }
                                            int32 Status = Response->GetResponseCode();
                                            FString RespBody = Response->GetContentAsString();
                                            if (Status == 401 || Status == 403)
                                            {
                                                if (ErrorTextBox.IsValid()) ErrorTextBox->SetText(FText::FromString(TEXT("Unauthorized token - please re-enter token in Settings")));
                                                if (ResponseTextBlock.IsValid()) ResponseTextBlock->SetText(FText::FromString(RespBody));
                                                return;
                                            }
                                            if (ResponseTextBlock.IsValid()) ResponseTextBlock->SetText(FText::FromString(RespBody));
                                        });
                                    });

                                    Request->ProcessRequest();
                                    return FReply::Handled();
                                }
                            }

                            // For other services fall back to health check
                            UAIBlueCopilotLibrary::RunHealthCheck(GEditor->GetEditorWorldContext().World());
                            return FReply::Handled();
                        })
                    ]

                    + SHorizontalBox::Slot().AutoWidth().Padding(2).VAlign(VAlign_Center)
                    [
                        SNew(SButton)
                        .Text(FText::FromString("Manage Tokens"))
                        .OnClicked_Lambda([]() -> FReply {
                            TSharedRef<SWindow> TokenWin = SNew(SWindow).Title(FText::FromString("Manage Stored Tokens")).ClientSize(FVector2D(560,260));
                            TokenWin->SetContent(
                                SNew(SVerticalBox)

                                // ChatGPT row
                                + SVerticalBox::Slot().AutoHeight().Padding(8)
                                [
                                    SNew(SHorizontalBox)
                                    + SHorizontalBox::Slot().AutoWidth().Padding(6).VAlign(VAlign_Center)[ SNew(STextBlock).Text(FText::FromString(FString::Printf(TEXT("ChatGPT: %s"), *GetMaskedTokenForService(TEXT("ChatGPT_Token_Protected"), TEXT("ChatGPT_Token"))))) ]
                                    + SHorizontalBox::Slot().AutoWidth().Padding(6)[ SNew(SButton).Text(FText::FromString("Reveal")).OnClicked_Lambda([]() -> FReply {
                                        FString Tok; if (GetTokenForService(TEXT("ChatGPT_Token_Protected"), TEXT("ChatGPT_Token"), Tok)) {
                                            TSharedRef<SWindow> RevealWin = SNew(SWindow).Title(FText::FromString("Reveal Token: ChatGPT")).ClientSize(FVector2D(420,120));
                                            TSharedPtr<SEditableTextBox> ShowBox;
                                            RevealWin->SetContent(
                                                SNew(SVerticalBox)
                                                + SVerticalBox::Slot().AutoHeight().Padding(6)[ SNew(STextBlock).Text(FText::FromString("Token (copy it now if needed):")) ]
                                                + SVerticalBox::Slot().AutoHeight().Padding(6)[ SAssignNew(ShowBox, SEditableTextBox).Text(FText::FromString(Tok)).IsReadOnly(true) ]
                                                + SVerticalBox::Slot().AutoHeight().HAlign(HAlign_Right).Padding(6)[ SNew(SButton).Text(FText::FromString("Close")).OnClicked_Lambda([RevealWin]() -> FReply { FSlateApplication::Get().RequestDestroyWindow(RevealWin); return FReply::Handled(); }) ]
                                            );
                                            FSlateApplication::Get().AddWindow(RevealWin);
                                        }
                                        return FReply::Handled(); }) ]
                                    + SHorizontalBox::Slot().AutoWidth().Padding(6)[ SNew(SButton).Text(FText::FromString("Revoke")).OnClicked_Lambda([TokenWinValue = TokenWin]() -> FReply { RevokeTokenForService(TEXT("ChatGPT_Token_Protected"), TEXT("ChatGPT_Token")); FSlateApplication::Get().RequestDestroyWindow(TokenWinValue); return FReply::Handled(); }) ]
                                ]

                                // GitHub Copilot row
                                + SVerticalBox::Slot().AutoHeight().Padding(8)
                                [
                                    SNew(SHorizontalBox)
                                    + SHorizontalBox::Slot().AutoWidth().Padding(6).VAlign(VAlign_Center)[ SNew(STextBlock).Text(FText::FromString(FString::Printf(TEXT("GitHub Copilot: %s"), *GetMaskedTokenForService(TEXT("GitHubCopilot_Token_Protected"), TEXT("GitHubCopilot_Token"))))) ]
                                    + SHorizontalBox::Slot().AutoWidth().Padding(6)[ SNew(SButton).Text(FText::FromString("Reveal")).OnClicked_Lambda([]() -> FReply {
                                        FString Tok; if (GetTokenForService(TEXT("GitHubCopilot_Token_Protected"), TEXT("GitHubCopilot_Token"), Tok)) {
                                            TSharedRef<SWindow> RevealWin = SNew(SWindow).Title(FText::FromString("Reveal Token: GitHub Copilot")).ClientSize(FVector2D(420,120));
                                            TSharedPtr<SEditableTextBox> ShowBox;
                                            RevealWin->SetContent(
                                                SNew(SVerticalBox)
                                                + SVerticalBox::Slot().AutoHeight().Padding(6)[ SNew(STextBlock).Text(FText::FromString("Token (copy it now if needed):")) ]
                                                + SVerticalBox::Slot().AutoHeight().Padding(6)[ SAssignNew(ShowBox, SEditableTextBox).Text(FText::FromString(Tok)).IsReadOnly(true) ]
                                                + SVerticalBox::Slot().AutoHeight().HAlign(HAlign_Right).Padding(6)[ SNew(SButton).Text(FText::FromString("Close")).OnClicked_Lambda([RevealWin]() -> FReply { FSlateApplication::Get().RequestDestroyWindow(RevealWin); return FReply::Handled(); }) ]
                                            );
                                            FSlateApplication::Get().AddWindow(RevealWin);
                                        }
                                        return FReply::Handled(); }) ]
                                    + SHorizontalBox::Slot().AutoWidth().Padding(6)[ SNew(SButton).Text(FText::FromString("Revoke")).OnClicked_Lambda([TokenWinValue = TokenWin]() -> FReply { RevokeTokenForService(TEXT("GitHubCopilot_Token_Protected"), TEXT("GitHubCopilot_Token")); FSlateApplication::Get().RequestDestroyWindow(TokenWinValue); return FReply::Handled(); }) ]
                                ]

