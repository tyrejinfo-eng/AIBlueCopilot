                    + SHorizontalBox::Slot().AutoWidth().Padding(2)[ SNew(STextBlock).Text(FText::FromString("Connection")) ]
                    + SHorizontalBox::Slot().AutoWidth().Padding(2)[
                        SAssignNew(ConnectionStatusBorder, SBorder)
                        .BorderBackgroundColor_Lambda([]() -> FLinearColor {
                            if (!GEditor) return FLinearColor::Gray;
                            UWorld* EditorWorld = GEditor->GetEditorWorldContext().World();
                            if (!EditorWorld) return FLinearColor::Gray;
                            return UAIBlueCopilotLibrary::IsCopilotReady(EditorWorld) ? FLinearColor(0.2f, 0.9f, 0.2f) : FLinearColor(0.9f, 0.2f, 0.2f);
                        })
                        .Padding(4)
                        [ SAssignNew(ConnectionStatusText, STextBlock)
                            .Text_Lambda([]() -> FText {
