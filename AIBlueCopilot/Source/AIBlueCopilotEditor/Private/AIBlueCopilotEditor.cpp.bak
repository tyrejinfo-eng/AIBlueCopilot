                                UWorld* EditorWorld = GEditor->GetEditorWorldContext().World();
                                if (!EditorWorld) return FText::GetEmpty();
                                bool bReady = UAIBlueCopilotLibrary::IsCopilotReady(EditorWorld);
                                bool bAttempt = false; GConfig->GetBool(TEXT("AIBlueCopilot"), TEXT("HasAttemptedConnect"), bAttempt, GEditorPerProjectIni);
                                if (bReady) return FText::FromString("Connected");
                                return bAttempt ? FText::FromString("Disconnected") : FText::GetEmpty();
                            })
                        ]
                    ]
                ]

                // Prompt input and send button
                + SVerticalBox::Slot().AutoHeight().Padding(4)
                [
                    SNew(SHorizontalBox)
                    + SHorizontalBox::Slot().FillWidth(1.0f).Padding(2)
                    [
                        SAssignNew(PromptTextBox, SEditableTextBox).Text(FText::FromString("Enter prompt or JSON here..."))
                    ]

                    + SHorizontalBox::Slot().AutoWidth().Padding(2).VAlign(VAlign_Center)
                    [
                        SAssignNew(PromptModeButton, SComboButton)
                        .ButtonContent(
                            SAssignNew(PromptModeLabel, STextBlock).Text_Lambda([]() -> FText { return FText::FromString(PromptMode); })
                        )
                        .OnGetMenuContent_Lambda([]() -> TSharedRef<SWidget> {
                            return SNew(SVerticalBox)

                                + SVerticalBox::Slot().AutoHeight().Padding(2)
                                [ SNew(SButton).Text(FText::FromString("Ask")).OnClicked_Lambda([]() -> FReply {
                                    PromptMode = TEXT("Ask");
                                    GConfig->SetString(TEXT("AIBlueCopilot"), TEXT("PromptMode"), *PromptMode, GEditorPerProjectIni);
                                    if (PromptModeLabel.IsValid()) PromptModeLabel->SetText(FText::FromString(PromptMode));
                                    return FReply::Handled();
                                }) ]

                                + SVerticalBox::Slot().AutoHeight().Padding(2)
                                [ SNew(SButton).Text(FText::FromString("Developer")).OnClicked_Lambda([]() -> FReply {
                                    PromptMode = TEXT("Developer");
                                    GConfig->SetString(TEXT("AIBlueCopilot"), TEXT("PromptMode"), *PromptMode, GEditorPerProjectIni);
                                    if (PromptModeLabel.IsValid()) PromptModeLabel->SetText(FText::FromString(PromptMode));
                                    return FReply::Handled();
                                }) ];
                        })
                    ]

                    + SHorizontalBox::Slot().AutoWidth().Padding(2)
                    [
                        SNew(SButton)
                        .Text(FText::FromString("Send Prompt"))
                        .OnClicked_Lambda([]() -> FReply {
                            if (GEditor && PromptTextBox.IsValid())
                            {
                                UWorld* EditorWorld = GEditor->GetEditorWorldContext().World();
                                if (EditorWorld)
                                {
                                    // use weak ptr to avoid dangling pointer in ticker
                                    TWeakObjectPtr<UWorld> WeakEditorWorld(EditorWorld);

                                    FString Prompt = PromptTextBox->GetText().ToString();

                                    if (PromptMode.Equals(TEXT("Developer")))
                                    {
                                        Prompt = FString::Printf(TEXT("[Developer Mode]\n%s"), *Prompt);
                                    }

                                    // Show prompt in the response window so user sees what's sent
                                    if (ResponseTextBlock.IsValid())
                                    {
                                        FString Prev = ResponseTextBlock->GetText().ToString();
                                        Prev += FString::Printf(TEXT("\n\n>> Prompt:\n%s\n\n"), *Prompt);
                                        ResponseTextBlock->SetText(FText::FromString(Prev));
                                        if (ResponseScrollBox.IsValid()) ResponseScrollBox->ScrollToEnd();
                                    }

                                    // show loading indicator
                                    if (LoadingIndicatorText.IsValid())
                                    {
                                        LoadingIndicatorText->SetText(FText::FromString("Loading"));
                                        LoadingIndicatorText->SetVisibility(EVisibility::Visible);
                                    }

                                    UAIBlueCopilotLibrary::SendCustomPrompt(EditorWorld, Prompt);
                                    FNotificationInfo SentInfo(FText::FromString(TEXT("Prompt sent to Copilot")));
                                    SentInfo.FadeOutDuration = 1.0f;
                                    SentInfo.ExpireDuration = 3.0f;
                                    FSlateNotificationManager::Get().AddNotification(SentInfo);

                                    // Start ticker to poll for responses
                                    double StartTime = FPlatformTime::Seconds();
                                    double Timeout = 60.0; // seconds (allow more time for large models)
                                    TSharedPtr<FString> LastSeenResponse = MakeShared<FString>();

                                    float PollInterval = UAIBlueCopilotLibrary::GetPollIntervalSeconds(EditorWorld);
                                    FTSTicker::GetCoreTicker().AddTicker(FTickerDelegate::CreateLambda([WeakEditorWorld, StartTime, Timeout, LastSeenResponse](float DeltaTime) -> bool {
                                        UWorld* EditorWorldPtr = WeakEditorWorld.Get();
                                        if (!EditorWorldPtr)
                                        {
                                            return false;
                                        }

                                        FString Response = UAIBlueCopilotLibrary::GetLastResponse(EditorWorldPtr);
                                                if (!Response.IsEmpty() && Response != *LastSeenResponse)
                                        {
                                            *LastSeenResponse = Response;
                                            if (ResponseTextBlock.IsValid())
                                            {
                                                FString Prev = ResponseTextBlock->GetText().ToString();
                                                Prev += FString::Printf(TEXT("-- Response:\n%s\n"), *Response);
                                                ResponseTextBlock->SetText(FText::FromString(Prev));
                                                if (ResponseScrollBox.IsValid()) ResponseScrollBox->ScrollToEnd();
                                            }

                                            // Try to parse JSON plan from response and offer an Apply button (dry-run)
                                            {
                                                TSharedPtr<FJsonValue> RootValue;
                                                TSharedRef<TJsonReader<>> JsonReader = TJsonReaderFactory<>::Create(Response);
                                                if (FJsonSerializer::Deserialize(JsonReader, RootValue) && RootValue.IsValid())
                                                {
                                                    bool bFoundPlan = false;
                                                    if (RootValue->Type == EJson::Array)
                                                    {
                                                        bFoundPlan = true;
                                                    }
                                                    else if (RootValue->Type == EJson::Object)
                                                    {
                                                        TSharedPtr<FJsonObject> Obj = RootValue->AsObject();
                                                        if (Obj->HasField(TEXT("plan")))
                                                        {
                                                            bFoundPlan = true;
                                                        }
                                                    }

                                                    if (bFoundPlan)
                                                    {
                                                        PendingPlanJson = Response;
                                                        FNotificationInfo PlanInfo(FText::FromString(TEXT("Dry-run plan detected (click Apply to enact)")));
                                                        PlanInfo.FadeOutDuration = 1.0f;
                                                        PlanInfo.ExpireDuration = 5.0f;
                                                        FSlateNotificationManager::Get().AddNotification(PlanInfo);
                                                    }
                                                }
                                            }

                                            if (LoadingIndicatorText.IsValid())
                                            {
                                                LoadingIndicatorText->SetVisibility(EVisibility::Collapsed);
                                            }

                                            FNotificationInfo RespInfo(FText::FromString(TEXT("Copilot responded")));
                                            RespInfo.FadeOutDuration = 1.0f;
                                            RespInfo.ExpireDuration = 3.0f;
                                            FSlateNotificationManager::Get().AddNotification(RespInfo);
                                            return false; // stop ticker
                                        }

                                        if (FPlatformTime::Seconds() - StartTime > Timeout)
                                        {
                                            // timed out
                                            if (ResponseTextBlock.IsValid())
                                            {
                                                FString Prev = ResponseTextBlock->GetText().ToString();
                                                Prev += FString::Printf(TEXT("-- No response (timed out)\n"));
                                                ResponseTextBlock->SetText(FText::FromString(Prev));
                                                if (ResponseScrollBox.IsValid()) ResponseScrollBox->ScrollToEnd();
                                            }

                                            if (LoadingIndicatorText.IsValid())
                                            {
                                                LoadingIndicatorText->SetVisibility(EVisibility::Collapsed);
                                            }

                                            // show error details if available
                                            if (ErrorTextBox.IsValid())
                                            {
                                                FString Err = UAIBlueCopilotLibrary::GetLastError(EditorWorldPtr);
                                                ErrorTextBox->SetText(FText::FromString(Err.IsEmpty() ? TEXT("Timeout or no response") : Err));
                                            }
                                            return false;
                                        }

                                        return true; // keep polling
                                    }), PollInterval);
                                }
                            }
                            return FReply::Handled();
                        })
                    ]
                ]

                // Response display (multiline, selectable, scrollable)
                + SVerticalBox::Slot().AutoHeight().Padding(4)
                [
                    SNew(SBorder)
                    .Padding(4)
                    [
                        SNew(SVerticalBox)

                        + SVerticalBox::Slot().FillHeight(1.0f).MaxHeight(300)
                        [
SAssignNew(ResponseScrollBox, SScrollBox)
                                    + SScrollBox::Slot()
                                    [
                                        SAssignNew(ResponseTextBlock, STextBlock)
                                            .AutoWrapText(true)
                                            .Text(FText::GetEmpty())
                                    ]
                        ]

                        + SVerticalBox::Slot().AutoHeight().Padding(2)
                        [
                            SNew(SHorizontalBox)

                            + SHorizontalBox::Slot().AutoWidth().Padding(2)
                            [
                                SNew(SButton)
                                .Text(FText::FromString("Clear"))
                                .OnClicked_Lambda([]() -> FReply {
                                    if (ResponseTextBlock.IsValid())
                                    {
                                        ResponseTextBlock->SetText(FText::GetEmpty());
                                        if (ResponseScrollBox.IsValid()) ResponseScrollBox->ScrollToEnd();
                                        FNotificationInfo ClearInfo(FText::FromString(TEXT("Response cleared")));
                                        ClearInfo.FadeOutDuration = 1.0f;
                                        ClearInfo.ExpireDuration = 2.0f;
                                        FSlateNotificationManager::Get().AddNotification(ClearInfo);
                                    }
                                    return FReply::Handled();
                                })
                            ]

                            + SHorizontalBox::Slot().AutoWidth().Padding(2)
                            [
                                SNew(SButton)
                                .Text(FText::FromString("Apply Plan"))
                                .IsEnabled_Lambda([]() -> bool {
                                    if (!GEditor) return false;
                                    UWorld* EditorWorld = GEditor->GetEditorWorldContext().World();
                                    return !PendingPlanJson.IsEmpty() && UAIBlueCopilotLibrary::GetAllowAssetChanges(EditorWorld);
                                })
                                .OnClicked_Lambda([]() -> FReply {
                                    if (!GEditor) return FReply::Handled();
                                    UWorld* EditorWorld = GEditor->GetEditorWorldContext().World();
                                    if (!EditorWorld) return FReply::Handled();
                                    if (PendingPlanJson.IsEmpty())
                                    {
                                        FSlateNotificationManager::Get().AddNotification(FNotificationInfo(FText::FromString(TEXT("No plan available to apply"))));
                                        return FReply::Handled();
                                    }

                                    UAIBlueCopilotLibrary::ApplyPlan(EditorWorld, PendingPlanJson);
                                    PendingPlanJson.Empty();
                                    if (ResponseTextBlock.IsValid())
                                    {
                                        FString Prev = ResponseTextBlock->GetText().ToString();
                                        Prev += TEXT("\n-- Plan applied\n");
                                        ResponseTextBlock->SetText(FText::FromString(Prev));
                                        if (ResponseScrollBox.IsValid()) ResponseScrollBox->ScrollToEnd();
                                    }
                                    FNotificationInfo AppliedInfo(FText::FromString(TEXT("Plan applied (or attempted). Check log for details")));
                                    AppliedInfo.FadeOutDuration = 1.0f;
                                    AppliedInfo.ExpireDuration = 5.0f;
                                    FSlateNotificationManager::Get().AddNotification(AppliedInfo);
                                    return FReply::Handled();
                                })
                            ]

                            + SHorizontalBox::Slot().AutoWidth().Padding(2)
                            [
                                SNew(SButton)
                                .Text(FText::FromString("Save"))
                                .OnClicked_Lambda([]() -> FReply {
                                    if (!ResponseTextBox.IsValid())
                                    {
                                        return FReply::Handled();
                                    }

                                    FString TextToSave = ResponseTextBlock.IsValid() ? ResponseTextBlock->GetText().ToString() : FString();

                                    IDesktopPlatform* DesktopPlatform = FDesktopPlatformModule::Get();
                                    if (DesktopPlatform)
                                    {
                                        void* ParentWindowHandle = nullptr;
                                        TArray<FString> OutFiles;
                                        const FString DefaultPath = FPaths::ProjectSavedDir();
                                        const FString DefaultFile = TEXT("copilot_response.txt");
                                        const FString FileTypes = TEXT("Text files (*.txt)|*.txt|JSON files (*.json)|*.json");

                                        bool bSaved = DesktopPlatform->SaveFileDialog(ParentWindowHandle, TEXT("Save Copilot Response"), DefaultPath, DefaultFile, FileTypes, 0, OutFiles);
                                        if (bSaved && OutFiles.Num() > 0)
                                        {
                                            if (FFileHelper::SaveStringToFile(TextToSave, *OutFiles[0]))
                                            {
                                                FNotificationInfo SavedInfo(FText::FromString(TEXT("Response saved")));
                                                SavedInfo.FadeOutDuration = 1.0f;
                                                SavedInfo.ExpireDuration = 2.0f;
                                                FSlateNotificationManager::Get().AddNotification(SavedInfo);
                                            }
                                            else
                                            {
                                                FNotificationInfo FailInfo(FText::FromString(TEXT("Failed to save response")));
                                                FailInfo.FadeOutDuration = 1.0f;
                                                FailInfo.ExpireDuration = 3.0f;
                                                FSlateNotificationManager::Get().AddNotification(FailInfo);
                                            }
                                        }
                                    }
                                    else
                                    {
                                        FNotificationInfo FailInfo(FText::FromString(TEXT("Save dialog not available")));
                                        FailInfo.FadeOutDuration = 1.0f;
                                        FailInfo.ExpireDuration = 3.0f;
                                        FSlateNotificationManager::Get().AddNotification(FailInfo);
                                    }

                                    return FReply::Handled();
                                })
                            ]

                            + SHorizontalBox::Slot().AutoWidth().Padding(2)
                            [
                                SNew(SButton)
                                .Text(FText::FromString("Show Copilot Log"))
                                .OnClicked_Lambda([]() -> FReply {
                                    FString LogDir = FPaths::ProjectLogDir();
                                    FString ProjectName = FApp::GetProjectName();
                                    FString LogFile = LogDir / (ProjectName + TEXT(".log"));
                                    FString LogContent;

                                    if (!FPaths::FileExists(LogFile))
                                    {
                                        // try to find the most recent log in the Logs folder
                                        TArray<FString> Found;
                                        IFileManager::Get().FindFiles(Found, *LogDir, TEXT("*.log"));
                                        if (Found.Num() > 0)
                                        {
                                            Found.Sort();
                                            LogFile = LogDir / Found.Last();
                                        }
                                    }

                                    if (FFileHelper::LoadFileToString(LogContent, *LogFile))
                                    {
                                        TArray<FString> Lines;
                                        LogContent.ParseIntoArrayLines(Lines);

                                        FString Filtered;
                                        for (const FString& L : Lines)
                                        {
                                            if (L.Contains(TEXT("[AIBLUE Copilot]") ) || L.Contains(TEXT("[AIBLUE LLM]") ) || L.Contains(TEXT("[AIBLUE]")))
                                            {
                                                Filtered += L + TEXT("\n");
                                            }
                                        }

                                        if (Filtered.IsEmpty())
                                        {
                                            Filtered = TEXT("No copilot log entries found in log file.");
                                        }

                                        if (ResponseTextBox.IsValid())
                                        {
                                            FString Prev = ResponseTextBox->GetText().ToString();
                                            Prev += TEXT("\n\n-- Copilot Log --\n");
                                            Prev += Filtered;
                                            ResponseTextBox->SetText(FText::FromString(Prev));
                                        }
                                    }
                                    else
                                    {
                                        FNotificationInfo FailInfo(FText::FromString(TEXT("Failed to read log file")));
                                        FailInfo.FadeOutDuration = 1.0f;
                                        FailInfo.ExpireDuration = 3.0f;
                                        FSlateNotificationManager::Get().AddNotification(FailInfo);
                                    }

                                    return FReply::Handled();
                                })
                            ]

                            // Loading throbber
                            + SHorizontalBox::Slot().AutoWidth().Padding(2).VAlign(VAlign_Center)
                            [
                                SAssignNew(LoadingIndicatorText, STextBlock).Text(FText::FromString(""))
                                    .Visibility(EVisibility::Collapsed)
                            ]

                            + SHorizontalBox::Slot().FillWidth(1.0f)
                            [
                                SNew(SVerticalBox)

                                + SVerticalBox::Slot().AutoHeight().Padding(2)
                                [
                                    SNew(STextBlock).Text(FText::FromString("Connection"))
                                ]

                                + SVerticalBox::Slot().AutoHeight().Padding(2)
                                [
                                    SAssignNew(ErrorTextBox, SMultiLineEditableText).IsReadOnly(true).AutoWrapText(true)
                                ]

                            ]

                        ]
                    ]
                ]
            ]
        ];

    return NewTab;
}
IMPLEMENT_MODULE(FAIBlueCopilotEditorModule, AIBlueCopilotEditor);
